diff --git a/deny.toml b/deny.toml
new file mode 100644
index 0000000..3c57861
--- /dev/null
+++ b/deny.toml
@@ -0,0 +1,28 @@
+[advisories]
+db-path = "~/.cargo/advisory-db"
+db-urls = ["https://github.com/rustsec/advisory-db"]
+yanked = "deny"
+
+[licenses]
+allow = [
+  "MIT",
+  "Apache-2.0",
+  "Apache-2.0 WITH LLVM-exception",
+  "BSD-2-Clause",
+  "BSD-3-Clause",
+  "ISC",
+  "Unicode-3.0",
+  "Zlib",
+]
+confidence-threshold = 0.8
+
+[bans]
+# Multiple versions of the same crate are common and mostly harmless in a
+# small workspace like this (transitive deps of clap/zbus/hickory each
+# pinning slightly different point releases) — not worth failing CI over
+# right now. Revisit if the tree grows.
+multiple-versions = "warn"
+
+[sources]
+unknown-registry = "deny"
+unknown-git = "deny"
